# ---- WhatsApp Cloud API (Meta) ----
WHATSAPP_TOKEN=                 # Token permanente del System User (no el temporal de 24h)
WHATSAPP_PHONE_NUMBER_ID=       # ID del número de WhatsApp Business (no el número en sí)
WHATSAPP_VERIFY_TOKEN=          # Inventa una cadena cualquiera; la pones también en Meta al verificar el webhook

# ---- Personas: nombres y números ----
# Los NOMBRES deben coincidir EXACTAMENTE con los del Excel (Panel, Listas, fórmulas).
PERSON1=Darry
PERSON2=Mimi
WA_PERSON1=            # número de PERSON1 en internacional sin + ni espacios, p.ej. 34666111222
WA_PERSON2=            # número de PERSON2

# ---- Google Sheets ----
GOOGLE_SHEET_ID=                # ID de la hoja (de la URL: docs.google.com/spreadsheets/d/<ESTO>/edit)
GOOGLE_SERVICE_ACCOUNT_EMAIL=   # xxx@xxx.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=             # La clave privada del JSON, entre comillas, con los \n incluidos

# ---- Google Gemini (parseo del lenguaje natural, nivel GRATIS de Google AI Studio) ----
GEMINI_API_KEY=                 # Crear en https://aistudio.google.com/apikey (gratis)
